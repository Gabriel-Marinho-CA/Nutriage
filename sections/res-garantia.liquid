{{ 'res-garantia.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign meta = product.metafields.custom.secao_garantia_novo.value
-%}

{% style %}
  #shopify-section-{{ section.id }}.res-gar-section {
    background-color: {{ section.settings.bg_color }};
    margin-block: {{ section.settings.margin_top }}px {{ section.settings.margin_bottom }}px;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #res-gar-{{ section.id }} .res-gar__imagem img {
    width: {{ section.settings.img_size }}px;
    max-width: 100%;
  }

  #res-gar-{{ section.id }} .res-gar__grid {
    gap: {{ section.settings.gap_colunas }}px;
  }

  #res-gar-{{ section.id }} .res-gar__titulo * {
    color: {{ section.settings.titulo_color }};
    font-size: {{ section.settings.titulo_size_desktop }}px;
    font-weight: {{ section.settings.titulo_weight }};
    line-height: {{ section.settings.titulo_line_height }};
  }

  #res-gar-{{ section.id }} .res-gar__conteudo * {
    color: {{ section.settings.conteudo_color }};
    font-size: {{ section.settings.conteudo_size_desktop }}px;
    line-height: {{ section.settings.conteudo_line_height }};
  }

  #res-gar-{{ section.id }} .res-gar__btn {
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    font-size: {{ section.settings.btn_font_size }}px;
  }

  @media screen and (max-width: 749px) {
    #res-gar-{{ section.id }} .res-gar__titulo * {
      font-size: {{ section.settings.titulo_size_mobile }}px;
    }

    #res-gar-{{ section.id }} .res-gar__conteudo * {
      font-size: {{ section.settings.conteudo_size_mobile }}px;
    }

  }
{% endstyle %}

<div id="res-gar-{{ section.id }}" class="res-gar">
  <div class="page-width">

    {%- if meta != blank -%}
      <div class="res-gar__grid">

        {%- comment -%} ── Imagem ── {%- endcomment -%}
        <div class="res-gar__imagem">
          {%- assign img_desktop = meta.imagem.value -%}
          {%- assign img_mobile  = meta.imagem_mobile.value -%}

          {%- if img_desktop != blank -%}
            {{
              img_desktop
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                class: 'res-gar__img--desktop',
                alt: img_desktop.alt | default: '',
                widths: '200, 400, 600'
            }}
          {%- endif -%}

          {%- if img_mobile != blank -%}
            {{
              img_mobile
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                class: 'res-gar__img--mobile',
                alt: img_mobile.alt | default: '',
                widths: '200, 300, 400'
            }}
          {%- elsif img_desktop != blank -%}
            {{
              img_desktop
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                class: 'res-gar__img--mobile',
                alt: img_desktop.alt | default: '',
                widths: '200, 300, 400'
            }}
          {%- endif -%}
        </div>

        {%- comment -%} ── Texto ── {%- endcomment -%}
        <div class="res-gar__texto">
          {%- if meta.titulo != blank -%}
            <div class="res-gar__titulo">{{ meta.titulo | metafield_tag }}</div>
          {%- endif -%}

          {%- if meta.conteudo != blank -%}
            <div class="res-gar__conteudo">{{ meta.conteudo | metafield_tag }}</div>
          {%- endif -%}

          {%- if meta.texto_botao != blank -%}
            <a
              href="{{ meta.url_botao.value | default: '#' }}"
              class="res-gar__btn"
            >
              {{ meta.texto_botao }}
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- else -%}
      {%- if request.design_mode -%}
        <div style="padding: 2rem; text-align: center; border: 2px dashed #ccc; border-radius: 8px; color: #999;">
          Metafield <strong>custom.secao_garantia_novo</strong> não encontrado neste produto.
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "RES - Garantia",
  "class": "res-gar-section",
  "settings": [
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "range",
      "id": "titulo_size_desktop",
      "min": 18,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Tamanho (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "titulo_size_mobile",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Tamanho (mobile)",
      "default": 24
    },
    {
      "type": "select",
      "id": "titulo_weight",
      "label": "Peso da fonte",
      "default": "700",
      "options": [
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — Semi-bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra-bold" }
      ]
    },
    {
      "type": "text",
      "id": "titulo_line_height",
      "label": "Line-height do título",
      "default": "1.2"
    },
    {
      "type": "color",
      "id": "titulo_color",
      "label": "Cor do título",
      "default": "#1a3c8c"
    },
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "range",
      "id": "conteudo_size_desktop",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Tamanho (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "conteudo_size_mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Tamanho (mobile)",
      "default": 15
    },
    {
      "type": "text",
      "id": "conteudo_line_height",
      "label": "Line-height do conteúdo",
      "default": "1.65"
    },
    {
      "type": "color",
      "id": "conteudo_color",
      "label": "Cor do conteúdo",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Botão"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Cor de fundo",
      "default": "#4caf50"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Cor do texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do texto",
      "default": 16
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "gap_colunas",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Gap entre colunas",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 64
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin superior",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin inferior",
      "default": 0
    },
    {
      "type": "header",
      "content": "Aparência"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "RES - Garantia",
      "category": "Res Meta - Seções"
    }
  ]
}
{% endschema %}
