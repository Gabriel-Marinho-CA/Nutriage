{% comment %}
  RES Split Slider — layout dividido com Swiper
  CSS: assets/res-split-slider.css
  Esquerda: imagem miniatura, tag, título, descrição, botão + setas
  Direita:  imagem desktop / mobile
  Cores configuráveis por bloco
{% endcomment %}

{{ 'res-split-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #res-split-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
  }
  @media screen and (min-width: 750px) {
    #res-split-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="res-split-{{ section.id }}" class="res-split-section">
  <div class="page-width">
    <div class="res-split__wrapper">
      <div id="res-split-swiper-{{ section.id }}" class="swiper res-split__swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- assign is_first = forloop.first -%}
            <div
              class="swiper-slide"
              style="--split-left-bg: {{ block.settings.left_bg }}; --split-tag-bg: {{ block.settings.tag_bg }}; --split-tag-color: {{ block.settings.tag_text_color }}; --split-title-color: {{ block.settings.title_color }}; --split-desc-color: {{ block.settings.desc_color }}; --split-btn-bg: {{ block.settings.btn_bg }}; --split-btn-color: {{ block.settings.btn_text_color }}; --split-arrow-color: {{ block.settings.arrow_color }};"
              {{ block.shopify_attributes }}
            >
              <div class="res-split__slide">
                {%- comment -%} ── Lado esquerdo ── {%- endcomment -%}
                <div class="res-split__left">
                  <div class="wrapper-content-res-split__left">
                    {%- if block.settings.product_image != blank -%}
                      <div class="res-split__thumb">
                        <img
                          src="{{ block.settings.product_image | image_url: width: block.settings.product_image.width }}"
                          alt="{{ block.settings.title | escape }}"
                          width="{{block.settings.product_image.width}}"
                          height="{{block.settings.product_image.height}}"
                          loading="lazy"
                        >
                      </div>
                    {%- endif -%}

                    {%- if block.settings.tag_label != blank -%}
                      <span class="res-split__tag">{{ block.settings.tag_label | escape }}</span>
                    {%- endif -%}

                    {%- if block.settings.title != blank -%}
                      <h2 class="res-split__title">{{ block.settings.title | escape }}</h2>
                    {%- endif -%}

                    {%- if block.settings.description != blank -%}
                      <div class="res-split__desc">{{ block.settings.description }}</div>
                    {%- endif -%}

                    {% if block.settings.button_label != blank and section.blocks.size > 1 %}
                      <div class="res-split__actions">
                        <a
                          href="{{ block.settings.button_url | default: '#' }}"
                          class="res-split__btn"
                        >
                          {{- block.settings.button_label | escape -}}
                        </a>
                        <div class="res-split__nav-wrap">
                          <button
                            class="res-split__nav-btn res-split__nav-btn--prev"
                            aria-label="{{ 'general.slider.previous_slide' | t }}"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="15 18 9 12 15 6"/>
                            </svg>
                          </button>
                          <button
                            class="res-split__nav-btn res-split__nav-btn--next"
                            aria-label="{{ 'general.slider.next_slide' | t }}"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="9 18 15 12 9 6"/>
                            </svg>
                          </button>
                        </div>
                      </div>
                    {% elsif block.settings.button_label != blank %}
                      <div class="res-split__actions">
                        <a
                          href="{{ block.settings.button_url | default: '#' }}"
                          class="res-split__btn"
                        >
                          {{- block.settings.button_label | escape -}}
                        </a>
                      </div>
                    {% elsif section.blocks.size > 1 %}
                      <div class="res-split__nav-wrap">
                        <button
                          class="res-split__nav-btn res-split__nav-btn--prev"
                          aria-label="{{ 'general.slider.previous_slide' | t }}"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"/>
                          </svg>
                        </button>
                        <button
                          class="res-split__nav-btn res-split__nav-btn--next"
                          aria-label="{{ 'general.slider.next_slide' | t }}"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                          </svg>
                        </button>
                      </div>
                    {% endif %}
                  </div>
                </div>

                {%- comment -%} ── Lado direito ── {%- endcomment -%}
                <div class="res-split__right">
                  {%- if block.settings.image_desktop != blank -%}
                    <img
                      class="res-split__img res-split__img--desktop{% if block.settings.image_mobile == blank %} res-split__img--all{% endif %}"
                      src="{{ block.settings.image_desktop | image_url: width: 900 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                  {%- if block.settings.image_mobile != blank -%}
                    <img
                      class="res-split__img res-split__img--mobile"
                      src="{{ block.settings.image_mobile | image_url: width: 600 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionEl = document.getElementById('res-split-{{ section.id }}');
    if (!sectionEl || typeof Swiper === 'undefined') return;

    var swiperEl = document.getElementById('res-split-swiper-{{ section.id }}');

    var swiper = new Swiper(swiperEl, {
      slidesPerView: 1,
      spaceBetween:10,
      loop: false,
    });

    // Todos os botões de cada slide recebem o evento — cores herdadas via CSS var do slide pai
    sectionEl.querySelectorAll('.res-split__nav-btn--prev').forEach(function (btn) {
      btn.addEventListener('click', function () { swiper.slidePrev(); });
    });
    sectionEl.querySelectorAll('.res-split__nav-btn--next').forEach(function (btn) {
      btn.addEventListener('click', function () { swiper.slideNext(); });
    });
  })();
</script>

{% schema %}
{
  "name": "Banner Split Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Lado esquerdo"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Imagem do produto (miniatura)"
        },
        {
          "type": "text",
          "id": "tag_label",
          "label": "Tag",
          "default": "Lançamento"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título do produto",
          "default": "Nome do Produto"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Descrição",
          "default": "<p>Descrição do produto aqui.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto do botão",
          "default": "Conhecer"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Link do botão"
        },
        {
          "type": "header",
          "content": "Lado direito"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Imagem (desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Imagem (mobile)"
        },
        {
          "type": "header",
          "content": "Cores"
        },
        {
          "type": "color",
          "id": "left_bg",
          "label": "Fundo do lado esquerdo",
          "default": "#1A4789"
        },
        {
          "type": "color",
          "id": "tag_bg",
          "label": "Fundo da tag",
          "default": "#F0A000"
        },
        {
          "type": "color",
          "id": "tag_text_color",
          "label": "Cor do texto da tag",
          "default": "#1A4789"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Cor do título",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "desc_color",
          "label": "Cor da descrição",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "btn_bg",
          "label": "Cor do botão",
          "default": "#4CAF50"
        },
        {
          "type": "color",
          "id": "btn_text_color",
          "label": "Cor do texto do botão",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "arrow_color",
          "label": "Cor das setas",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Split Slider",
      "category": "Res - Seções",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "tag_label": "Lançamento",
            "title": "Magnesium Ultra 3",
            "description": "<p>O <strong>Magnésio + Zinco</strong> que você já conhece.</p>",
            "button_label": "Conhecer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
