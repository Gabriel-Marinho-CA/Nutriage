                      Adicionar ao carrinho
                    </button>
                  {% else %}
                    <button class="text-lg buy-button-pdp py-3 px-4 rounded-full w-full" style="color:#fff">
                      <span class="relative z-[1]"> Avise-me quando chegar </span>
                    </button>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div id="banners-buy-area" class="mt-10">
        <ul class="flex items-center gap-5 lg:flex-col">
          {% for item in banners_buy_area.value %}
