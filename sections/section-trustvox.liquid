{{ 'trustvox-reviews.css' | asset_url | stylesheet_tag }}

<style>
  /* Apenas o necessário para o overlay de estrelas (largura controlada via JS) */
  .ts-v-stars { position: relative; width: 137px; }
  .ts-v-stars-background { display: flex; width: 137px; }
  .ts-v-stars-foreground { position: absolute; top: 0; }
  .ts-v-stars-foreground span { display: flex; overflow: hidden; }
  .ts-v-stars-foreground svg { min-width: 1.5rem; }
</style>

{%- comment -%} Elementos hidden com os IDs dos produtos para o fetch da API Trustvox {%- endcomment -%}
<div class="trustvox-fetch" data-code="{{ product.id }}" style="display:none;"></div>
{%- if product.metafields.custom.kits != blank -%}
  {%- for product_kit in product.metafields.custom.kits.value -%}
    <div class="trustvox-fetch" data-code="{{ product_kit.id }}" style="display:none;"></div>
  {%- endfor -%}
{%- endif -%}

<section id="reviews-sec">
  <div class="page-width">

    <div data-trustvox-certificate-fixed></div>

    <div id="_sincero_widgets" class="trustvox-widget">
      <div class="ts-product-reviews">

        {%- comment -%} Overview: nota + recomendação {%- endcomment -%}
        <section class="tv-overview">

          {%- comment -%} Bloco de nota {%- endcomment -%}
          <div class="tv-rating">
            <div class="tv-rating__score">
              <span class="tv-rating__value custom-rating-note--js">4.8</span>
              <span class="tv-rating__of">/5</span>
            </div>
            <p class="tv-rating__label">Nota do produto</p>
            <div class="ts-v-stars">
              <span class="ts-v-stars-background">
                {%- for i in (1..5) -%}
                  <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 512 512">
                    <path fill="#ddd" d="M457.888 210.672l-139.504-20.272-62.384-126.4-62.384 126.4-139.504 20.272 100.944 98.384-23.84 138.928 124.768-65.6 124.768 65.6-23.84-138.928c0 0 100.944-98.384 100.944-98.384z"/>
                  </svg>
                {%- endfor -%}
              </span>
              <span class="ts-v-stars-foreground">
                <span class="custom-star-bg--js">
                  {%- for i in (1..5) -%}
                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 512 512">
                      <path fill="#ffc400" d="M457.888 210.672l-139.504-20.272-62.384-126.4-62.384 126.4-139.504 20.272 100.944 98.384-23.84 138.928 124.768-65.6 124.768 65.6-23.84-138.928c0 0 100.944-98.384 100.944-98.384z"/>
                    </svg>
                  {%- endfor -%}
                </span>
              </span>
            </div>
            <p class="tv-rating__based-on">
              Baseado em <span class="custom-based-on--js">5</span> avaliações
            </p>
          </div>

          {%- comment -%} Bloco de recomendação {%- endcomment -%}
          <div class="tv-recommend">
            <div class="tv-recommend__circle-wrap">
              <svg height="66" width="66">
                <circle stroke="#e2e2e2" stroke-width="5" fill="transparent" r="28" cx="32" cy="32"/>
                <circle
                  class="custom--circle-percentage--js"
                  stroke="#ffc400"
                  stroke-dasharray="175.93 175.93"
                  stroke-width="5"
                  fill="transparent"
                  r="28" cx="32" cy="32"
                  style="stroke-dashoffset: 0px; transform: rotate(-90deg); transform-origin: 50% 50%;"
                />
              </svg>
              <span class="tv-recommend__pct custom-percentage--js-reviews">100%</span>
            </div>
            <p class="tv-recommend__text">dos clientes recomendam este produto</p>
          </div>

        </section>

        {%- comment -%} Lista de avaliações {%- endcomment -%}
        <section>
          <div class="tv-list-header">
            <h4 class="tv-list-header__title">Avaliações mais recentes</h4>
            <div class="tv-list-header__filter">
              <label for="filter-reviews">exibindo:</label>
              <select id="filter-reviews" onchange="filterReviews(this.value)">
                <option value="most-recent">Mais recentes</option>
                <option value="positive">Positivas</option>
                <option value="negative">Negativas</option>
                <option value="worth">Mais úteis</option>
              </select>
            </div>
          </div>

          <div id="reviews-container"></div>

          <div id="load-more-reviews" class="tv-load-more">
            <button id="load-more-btn" class="tv-load-more__btn">Carregar mais</button>
          </div>

          <div class="tv-footer">
            <a
              href="https://site.trustvox.com.br/conheca-a-trustvox?utm_source=widget-rareviews&utm_medium=quizz&utm_campaign=nutriage.com.br"
              target="_blank"
            >
              <img title="RA Icone" src="https://static.trustvox.com.br/sincero/img/ra-icon.svg" width="20" height="20" alt="RA Icone">
              Avaliações confiáveis do
              <img title="Reclame Aqui" src="https://static.trustvox.com.br/sincero/img/logo-reclameaqui.svg" width="80" height="16" alt="Reclame Aqui">
            </a>
          </div>
        </section>

      </div>
    </div>

    <div id="_trustvox_colt"></div>
  </div>
</section>

{%- comment -%} Fallback: widget nativo Trustvox (oculto por padrão) {%- endcomment -%}
<section id="reviews-sec-2" style="display: none;">
  <div class="container">
    <div data-trustvox-certificate-fixed></div>
    <div id="_trustvox_widget"></div>
    <div id="_trustvox_colt"></div>
  </div>
</section>

<script type="text/javascript" src="//certificate.trustvox.com.br/widget.js" defer></script>
<script type="text/javascript" src="//colt.trustvox.com.br/colt.min.js" defer></script>
<script defer>
  var _trustvox_colt = _trustvox_colt || [];
  _trustvox_colt.push(['_storeId', '123342'], ['_limit', '7']);
</script>

<script src="{{ 'trustvox-reviews.js' | asset_url }}" defer></script>

{%- schema -%}
{
  "name": "TrustVox",
  "settings": [],
  "presets": [{ "name": "TrustVox" }]
}
{%- endschema -%}
