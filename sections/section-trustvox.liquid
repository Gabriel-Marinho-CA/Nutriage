                      | times: 0.93
                      | ceil
                      | plus: 99
                      | divided_by: 100
                      | floor
                      | times: 100
                    %}
                    {% assign qtd_potes = product_kit.metafields.custom.quantidade_de_potes
                      | split: ' '
