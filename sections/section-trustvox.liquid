                  {% endif %}
                  <h3 class="bebas-font text-4xl text-white">{{ text_quantity_pot | default: '1 POTE' }}</h3>
                  {% assign price_pix_1 = product.price
                    | times: 0.93
                    | ceil
                    | plus: 99
                    | divided_by: 100
                    | floor
                    | times: 100
