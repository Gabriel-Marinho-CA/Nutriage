                </div>
                <div class="text-[#1a4889] price">
                  <p class="line-through opacity-60 text-sm">{{ product.compare_at_price | money }}</p>
                  {% assign P1 = product.price | money_without_currency %}
                  {% assign val1 = P1
                    | times: power
                    | divided_by: 12
                    | round: 2
                    | times: 100
                    | money_without_currency
                  %}
                  <p class="font-black text-3xl leading-none">12x de {{ val1 }}</p>
                  <p class="font-bold text-sm">{{ price_pix_1 | money }} no Pix</p>
                </div>

