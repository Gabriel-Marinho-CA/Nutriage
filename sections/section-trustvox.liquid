                    </div>
                  </div>
                  <div class="flex justify-center">
                    <img
                      src="{{ product_kit.featured_image | image_url: width: 203 }}"
                      alt="{{ product_kit.title }}"
                      width="160"
                    >
                  </div>
                </div>

                <div class="card-body">
                  <div class="text-[#1a4889]">
                    <p class="bebas-font text-xl">
                      {{ product_kit.metafields.custom.quantidade_de_potes | default: product_kit.title }}
                    </p>
                    <p class="text-sm">
                      Tratamento
                      {{ product_kit.metafields.custom.tempo_de_tratamento | default: 'Tratamento Completo' }}
                    </p>
                  </div>
                  <div class="text-[#1a4889] price">
                    <p class="line-through opacity-60 text-sm">{{ product_kit.compare_at_price | money }}</p>
                    {% assign PK = product_kit.price | money_without_currency %}
                    {% assign valK = PK
                      | times: power
                      | divided_by: 12
                      | round: 2
                      | times: 100
                      | money_without_currency
                    %}
                    <p class="font-black text-3xl leading-none">12x de {{ valK }}</p>
                    <p class="font-bold text-sm">{{ pix_k | money }} no Pix</p>
                  </div>
                  {% if product_kit.available %}
                    <button
                      onclick="addToCart('{{ product_kit.first_available_variant.id }}')"
                      class="btn-green text-lg py-3"
