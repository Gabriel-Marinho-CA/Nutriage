<style>
  /* Container principal */
  .reviews-section {
   /* background-color: #000;  dark:bg-black */
  }

  .container {
    padding-top: 2.5rem;   /* lg:py-10 */
    padding-bottom: 2.5rem;
  }

  @media (min-width: 1024px) {
    .container {
      padding-top: 4rem;   /* min_lg:py-16 */
      padding-bottom: 4rem;
    }
  }

  /* Rating block */
  .ts-v-stars {
    position: relative;
    width: 137px;
  }

  .ts-v-stars-background {
    display: flex;
    width: 137px;
  }

  .ts-v-stars-foreground {
    position: absolute;
    top: 0;
  }

  .ts-v-stars-foreground span {
    display: flex;
    overflow: hidden;
  }

  .ts-v-stars-foreground svg {
    min-width: 1.5rem; /* min-w-6 */
  }

  /* Wrapper título */
  .wrapper-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #e2e2e2;
    padding-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .wrapper-title {
      flex-direction: column;
      gap: 1rem;
    }
  }

  .wrapper-title h4 {
    color: #2c2c2c;
    font-size: 1.25rem;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .wrapper-title h4 {
      font-size: 1.125rem;
    }
  }

  /* Select */
  .select {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .select select {
    background-color: #fff;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    color: #6c6c6c;
  }

  /* Load more button */
  #load-more-reviews {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
  }

  #load-more-reviews button {
    background: none;
    border: 1px solid #2c2c2c;
    color: #2c2c2c;
    font-size: 1.125rem;
    text-transform: uppercase;
    border-radius: 0.375rem;
    padding: 0.5rem;
    text-align: center;
  }

  /* Footer */
  .ts-v-footer-container {
    display: flex;
    align-items: center;
    color: inherit;
  }

  /* Percentage circle */
  .ts-v-percentage-circle {
    height: 66px;
    width: 66px;
  }

  /* Dark mode overrides */
  @media (prefers-color-scheme: dark) {
    .reviews-section {
      background-color: #000;
    }

    .ts-product-reviews {
      background-color: #000;
    }

    .ts-v-rating,
    .ts-v-recommendations,
    .wrapper-title h4,
    .select label,
    #load-more-reviews button,
    .ts-v-footer-container {
      color: #fff;
    }

    #load-more-reviews button {
      border-color: #fff;
    }
  }
</style>

