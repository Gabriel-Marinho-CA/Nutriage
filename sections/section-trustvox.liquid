<style>
    /* ==========================================================================
       1. GERAL, REVIEWS E VÍDEO (Configurações do Sistema)
       ========================================================================== */

       .buy-button-pdps {}

    #reviews-sec .review-card-title { font-weight: 600; }
    #product-info-2 h3 strong { display: block; }
    .restock-rocket-button-container-float-right { opacity: 0 !important; }
    .restock-rocket-button-product { display: inline-block !important; }
    .card:has(.restock-rocket-button) .buy-button-pdp { display: none; }
    #reviews-sec-2 .ts-product-reviews { display: none !important; }

    /* Animação de Brilho */
    @keyframes pulseShineBt {
      0% { background-position: 0% 50%; }
      100% { background-position: 100% 50%; }
    }

    /* Botões de Compra PDPS */
    .buy-button-pdps, .restock-rocket-button {
      position: relative;
      overflow: hidden;
      z-index: 1;
    }

    .buy-button-pdps::before, .restock-rocket-button::before {
      content: "";
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 9999px;
      /*background: linear-gradient(45deg, #24c6dc, #514a9d, #24c6dc);*/
      background-size: 400% 400%;
      animation: pulseShineBt 1s ease infinite alternate both;
      transition: all 0.2s ease;
      z-index: -1;
    }

    /* Dark Mode - Reviews & Botões */
   /* .dark .buy-button-pdps::before { background: linear-gradient(45deg, #FFC400, #FFE977); }*/
    .dark .list-reviews .ts-vote-question,
    .dark .list-reviews .material-icons,
    .dark .list-reviews .ts-count,
    .dark .carousel__icon,
    .dark .ts-question-count,
    .dark .trustvox-widget .ts-customer-questions__title,
    .dark .ts-filter-question label,
    .dark .ts-questions-list-item .ts-title,
    .dark .ts-title_sub,
    .dark .ts-date,
    .dark .ts-section h2 { color: #fff; }
    .dark .ts-customer-questions { background-color: #000; }

    /* Floating Video Area */
    #videoOverlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(5px);
      z-index: 40;
      opacity: 0;
      transition: opacity 0.3s ease;
      cursor: pointer;
    }
    #videoOverlay.active { display: block; opacity: 1; }

    #floatingVideo {
      position: fixed;
      bottom: 1.5rem;
      left: 1rem;
      width: 9rem;
      height: 9rem;
      border-radius: 50%;
      overflow: hidden;
      box-shadow: 0 3px 7px rgba(0, 0, 0, 0.7);
      cursor: pointer;
      transition: all 0.3s ease-in-out;
      z-index: 50;
    }

    #floatingVideo video { width: 100%; height: 100%; object-fit: cover; }

    #floatingVideo.expanded {
      width: auto;
      height: 80vh !important;
      top: 50%;
      left: 50% !important;
      transform: translate(-50%, -50%);
      border-radius: 12px;
    }
    #floatingVideo.expanded video { object-fit: contain; }

    #closeVideo {
      display: none;
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      background: rgba(0, 0, 0, 0.6);
      color: white;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      z-index: 60;
    }
    #closeVideo.active { display: block; }

    /* Responsivo Geral (Mobile) */
    @media (max-width: 767px) {
      .list-reviews { flex-direction: column-reverse; align-items: flex-start; }
      .list-reviews .wrapper-user-name { display: flex; gap: 1rem; }
      #floatingVideo:not(.rounded-lg) { right: 1rem; left: auto; bottom: 150px; width: 70px; height: 70px; }
      #floatingVideo.rounded-lg { height: auto; width: 86%; }
      #floatingVideo.expanded { width: 72% !important; height: fit-content !important; }
      #floatingVideo.expanded video { height: fit-content; }
    }

    /* ==========================================================================
       2. SEÇÃO DE KITS (PARTE NOVA - ISOLADA)
       ========================================================================== */

    #buy-area {}

    .cards { margin-top: 5rem; margin-bottom: 1rem; }

    /* Estrutura do Card */
    .card {
      background: #fff !important;
      overflow: visible !important;
      padding: 0 !important;
      border: none !important;
      border-radius: 25px;
      margin: auto -20px 0;
      --tw-shadow: 2px 2px 10px rgba(0, 0, 0, .2) !important;
    }

    /* Cabeçalho e Tipografia */
    .kit-header {
      padding: 25px 10px 55px;
      position: relative;
      background: #D1E3FF;
      border-radius: 25px;
      margin: 0 -20px 100px;
      height: 200px;
    }

    .kit-header img { z-index: 3; margin-top: -45px; }

    h3.bebas-font {
      font-family: 'Bebas Neue', sans-serif !important;
      text-transform: uppercase;
      line-height: 1;
      font-size: 70px;
      color: #1A4889;
      margin: -7px 0 -10px;
    }

    /* Selos e Pílulas */
    .champion-label {
      font-family: 'Bebas Neue', sans-serif !important;
      background: #1a4889;
      color: #D4B373;
      font-size: 28px;
      padding: 5px 0 0;
      width: 100%;
      border-radius: 25px 25px 0 0;
    }

    .unit-pill {
      background: #fff;
      color: #1a4889;
      padding: 6px 15px;
      border-radius: 25px;
      font-weight: 700;
      width: max-content;
      margin: 15px auto 40px;
      z-index: 10;
      font-family: Helvetica, Arial, sans-serif !important;
      font-size: 16px;
    }

    /* Lógica de Cores por Ordem (Kit 5 e Kit 3) */
    .card[style*="order:2"] .top-sell,
    .card[style*="order:3"] .top-sell {
      margin: -30px auto 0;
      width: 85%;
      border-radius: 25px;
      padding: 0 0 25px;
      transform: translateY(-20%);
      margin-bottom: 2%;
    }

    .card[style*="order:2"] .top-sell { background: #d4b373; } /* Kit Dourado */
    .card[style*="order:3"] .top-sell { background: #1A4889; margin-bottom: 10%; } /* Kit Azul */

    .card[style*="order:2"] h3.bebas-font,
    .card[style*="order:3"] h3.bebas-font { margin: 10px auto 0; padding: 5px 15px; line-height: 0.8em; }

    .card[style*="order:3"] h3.bebas-font { color: #fff; padding: 20px 20px 10px; }
    .card[style*="order:2"] .top-sell .unit-pill,
    .card[style*="order:3"] .top-sell .unit-pill { margin: 5px auto -40px !important; }

      .card[style*="order:2"] .kit-header img{
    width: 200px;
    }
    .card[style*="order:3"] .kit-header img{
    width: 170px;
    }

    /* Corpo do Card e Preços */
    .card-body {
      padding: 0;
      background-color: #fff;
      border-radius: 25px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .card-body p { font-family: Helvetica, Arial, sans-serif !important; font-size: 18px; }
    .card-body .price { font-weight: 700; }
    .card-body .price p { line-height: 1.2em; font-family: Helvetica, Arial, sans-serif !important; }
    .card-body .price > p.font-black.text-3xl { font-size: 36px; }

    /* Espaçamentos internos do corpo */
    .card-body > div:nth-child(2),
    .card-body > div:nth-child(3) { margin-top: 15px; margin-bottom: 15px; }

    /* Botão de Compra dos Kits */
    .btn-green {
      background: #5aac3f !important;
      color: white !important;
      font-weight: 700 !important;
      text-transform: uppercase;
      border-radius: 25px !important;
      padding: 12px 20px !important;
      border: none !important;
      transition: transform 0.2s;
      font-size: 15px;
      letter-spacing: 0.4px;
      font-family: Helvetica, Arial, sans-serif !important;
      cursor: pointer;
    }
    .btn-green:hover { transform: scale(1.02); }

      /* 1. Garantir que o botão suporte o brilho */
  .btn-green {
      position: relative; /* Essencial para o brilho não flutuar fora do botão */
      overflow: hidden;    /* Essencial para o brilho sumir ao sair da borda */
  }

  /* 2. O efeito de brilho (Flash) */
  .btn-green::after {
      content: "";
      position: absolute;
      top: 0;
      left: -100%; /* Começa fora do botão à esquerda */
      width: 50%;  /* Largura da faixa de brilho */
      height: 100%;
      background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.2) 50%,
          rgba(255, 255, 255, 0) 100%
      );
      transform: skewX(-25deg); /* Inclinação do brilho */
      animation: move-shine 3s infinite; /* Loop infinito a cada 3 segundos */
  }

  /* 3. A animação que faz o brilho correr */
  @keyframes move-shine {
      0% {
          left: -100%;
      }
      90% {
          /* O brilho agora leva 40% do tempo (2 segundos) para atravessar,
             em vez de apenas 20% (0.6 segundos) como estava antes. */
          left: 150%;
      }
      100% {
          left: 150%; /* O restante do tempo ele aguarda para reiniciar */
      }
  }

    /* Ajustes Responsivos dos Kits */
    @media(min-width: 900px) {
      #buy-area .grid { justify-content: space-between; }
    }

    @media(max-width: 900px) {
      .cards { margin-top: 1rem; margin-bottom: 1rem; }
      .cards .wrapper-products-kits { gap: 85px; }
    }
</style>

