                      | plus: 0
                    %}
                    {% assign default_potes = product_kit.metafields.custom.quantidade_de_potes
                      | split: ' '
                      | first
                      | plus: 0
                    %}

                    {% if qtd_potes == 0 %}{% assign qtd_potes = 1 %}{% endif %}

