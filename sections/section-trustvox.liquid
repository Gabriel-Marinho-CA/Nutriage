{% if float_video != blank %}
  <!-- Fundo escurecido -->
  <div id="videoOverlay"></div>

  <!-- Vídeo flutuante -->
  <div id="floatingVideo">
    {{ float_video.value | video_tag: autoplay: true, muted: true, loop: true, playsinline: true }}
    <button id="closeVideo">✕</button>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('floatingVideo');
      const overlay = document.getElementById('videoOverlay');
      const closeBtn = document.getElementById('closeVideo');
      const video = container.querySelector('video');
      let expanded = false;

      const expandVideo = () => {
        if (expanded) return;
        expanded = true;

        container.classList.add('expanded');
        overlay.classList.add('active');
        closeBtn.classList.add('active');

        video.currentTime = 0;
        video.muted = false;
        video.controls = true;
        video.play();
      };

      const closeVideo = () => {
        expanded = false;

        container.classList.remove('expanded');
        overlay.classList.remove('active');
        closeBtn.classList.remove('active');

        video.muted = true;
        video.controls = false;
      };

      container.addEventListener('click', () => {
        if (!expanded) expandVideo();
      });

      closeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        closeVideo();
      });

      overlay.addEventListener('click', closeVideo);
    });
  </script>
{% endif %}
