{% comment %}
  RES Footer
  CSS: assets/res-footer.css
  Blocks: links | support_institutional | payments_security
{% endcomment %}

{{ 'res-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #res-footer-{{ section.id }} {
    --res-footer-bg:          {{ section.settings.bg_color }};
    --res-footer-accent:      {{ section.settings.accent_color }};
    --res-footer-title-color: {{ section.settings.title_color }};
    --res-footer-link-color:  {{ section.settings.link_color }};
    --res-footer-text-color:  {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
  }
  @media screen and (min-width: 750px) {
    #res-footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-top: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer id="res-footer-{{ section.id }}" class="res-footer">
  {%- comment -%} ── Colunas principais ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="res-footer__main page-width scroll-trigger animate--slide-in">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'links' -%}
            <div class="res-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <div class="res-footer__accordion-item">
                  <button class="res-footer__accordion-btn" aria-expanded="false">
                    {{- block.settings.title | escape -}}
                    <svg
                      class="res-footer__chevron"
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="res-footer__accordion-body">
                    {%- if block.settings.menu.links.size > 0 -%}
                      <ul class="res-footer__links{% if block.settings.columns == '2' %} res-footer__links--2col{% endif %}">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a href="{{ link.url }}" class="res-footer__link">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              {%- else -%}
                {%- if block.settings.menu.links.size > 0 -%}
                  <ul class="res-footer__links{% if block.settings.columns == '2' %} res-footer__links--2col{% endif %}">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}" class="res-footer__link">{{ link.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              {%- endif -%}
            </div>

          {%- when 'support_institutional' -%}
            <div class="res-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.title_1 != blank -%}
                <div class="res-footer__accordion-item">
                  <button class="res-footer__accordion-btn" aria-expanded="false">
                    {{- block.settings.title_1 | escape -}}
                    <svg
                      class="res-footer__chevron"
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="res-footer__accordion-body">
                    {%- if block.settings.menu_1.links.size > 0 -%}
                      <ul class="res-footer__links">
                        {%- for link in block.settings.menu_1.links -%}
                          <li>
                            <a href="{{ link.url }}" class="res-footer__link">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              {%- if block.settings.title_2 != blank -%}
                <div class="res-footer__accordion-item">
                  <button class="res-footer__accordion-btn" aria-expanded="false">
                    {{- block.settings.title_2 | escape -}}
                    <svg
                      class="res-footer__chevron"
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="res-footer__accordion-body">
                    {%- if block.settings.menu_2.links.size > 0 -%}
                      <ul class="res-footer__links">
                        {%- for link in block.settings.menu_2.links -%}
                          <li>
                            <a href="{{ link.url }}" class="res-footer__link">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>

          {%- when 'payments_security' -%}
            <div class="res-footer__col res-footer__col--payments" {{ block.shopify_attributes }}>
              {%- if block.settings.payment_title != blank -%}
                <div class="res-footer__accordion-item">
                  <button class="res-footer__accordion-btn" aria-expanded="false">
                    {{- block.settings.payment_title | escape -}}
                    <svg
                      class="res-footer__chevron"
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="res-footer__accordion-body">
                    <div class="res-footer__payment-grid">
                      {%- for i in (1..9) -%}
                        {%- assign show_key = 'show_pay_' | append: i -%}
                        {%- assign icon_key = 'icon_pay_' | append: i -%}
                        {%- if block.settings[show_key] and block.settings[icon_key] != blank -%}
                          <div class="res-footer__payment-icon">
                            <img
                              src="{{ block.settings[icon_key] | image_url: width: 80 }}"
                              alt="{{ block.settings[icon_key].alt | escape }}"
                              width="80"
                              height="35"
                              loading="lazy"
                            >
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.security_title != blank -%}
                <div class="res-footer__accordion-item">
                  <button class="res-footer__accordion-btn" aria-expanded="false">
                    {{- block.settings.security_title | escape -}}
                    <svg
                      class="res-footer__chevron"
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="res-footer__accordion-body">
                    <div class="res-footer__seals">
                      {%- if block.settings.seal_1 != blank -%}
                        <img
                          src="{{ block.settings.seal_1 | image_url: width: 140 }}"
                          alt="{{ block.settings.seal_1.alt | escape }}"
                          width="140"
                          height="76"
                          class="res-footer__seal"
                          loading="lazy"
                        >
                      {%- endif -%}
                      {%- if block.settings.seal_2 != blank -%}
                        <img
                          src="{{ block.settings.seal_2 | image_url: width: 140 }}"
                          alt="{{ block.settings.seal_2.alt | escape }}"
                          width="140"
                          height="76"
                          class="res-footer__seal"
                          loading="lazy"
                        >
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
      <div class="res-footer__accordion-item large-up-hide medium-hide">
        <button class="res-footer__accordion-btn" aria-expanded="false">
          Atendimento
          <svg
            class="res-footer__chevron"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="res-footer__accordion-body atendimento">
          {{ section.settings.extra_text }}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Linha inferior: logo + textos ── {%- endcomment -%}
  <div class="page-width scroll-trigger animate--slide-in">
    <div class="res-footer__bottom">
      <div class="res-footer__brand">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            style="width: {{ section.settings.logo_width }}px"
            loading="lazy"
            class="res-footer__logo"
          >
        {%- else -%}
          <span class="res-footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.logo_text != blank -%}
          <div class="res-footer__brand-text">{{ section.settings.logo_text }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.extra_text != blank -%}
        <div class="res-footer__info-text small-hide">{{ section.settings.extra_text }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Barra de copyright ── {%- endcomment -%}
  <div class="page-width scroll-trigger animate--slide-in">
    <div class="res-footer__copyright-bar">
      {%- if section.settings.copyright_text != blank -%}
        <span class="res-footer__copyright-text">{{ section.settings.copyright_text | escape }}</span>
      {%- endif -%}
      {%- if section.settings.brand_logo != blank or section.settings.brand_label != blank -%}
        <div class="res-footer__tech">
          {%- if section.settings.brand_label != blank -%}
            <span class="res-footer__tech-label">{{ section.settings.brand_label | escape }}</span>
          {%- endif -%}
          {%- if section.settings.brand_logo != blank -%}
            <a href="{{  section.settings.link_tec }}" title="Tecnologia Resultate">
              <img
                src="{{ section.settings.brand_logo | image_url: width: section.settings.brand_logo_width }}"
                alt="{{ section.settings.brand_logo.alt | escape }}"
                style="width: {{ section.settings.brand_logo_width }}px"
                loading="lazy"
              >
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<script>
  (function () {
    function init() {
      var footer = document.getElementById('res-footer-{{ section.id }}');
      if (!footer) return;
      footer.querySelectorAll('.res-footer__accordion-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var item = btn.closest('.res-footer__accordion-item');
          var open = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
          item.classList.toggle('is-open', !open);
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

