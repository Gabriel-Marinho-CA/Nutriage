{{ 'res-timer-produto.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign prod = section.settings.product
  assign variant = null
  if prod != blank
    assign variant = prod.selected_or_first_available_variant
  endif

  assign img = section.settings.imagem
  if img == blank and prod != blank
    assign img = prod.featured_image
  endif
-%}

{% style %}
  #shopify-section-{{section.id }}.res-timer-produto-section {
    margin-block: {{ section.settings.margin_top }}px  {{ section.settings.margin_bottom }}px;
  }
  #res-tp-{{ section.id }} .res-tp__grid{
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-radius: {{ section.settings.border_radius }}px;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
 

    @media (max-width:750px) {
      padding-inline: 1rem;
    }
  }

  #res-tp-{{ section.id }} .res-tp__titulo {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
  }

  #res-tp-{{ section.id }} .res-tp__preco-atual-valor {
    color: {{ section.settings.price_atual_color }};
    font-size: {{ section.settings.price_size_desktop }}px;
    font-weight: {{ section.settings.price_weight }};
  }

  #res-tp-{{ section.id }} .res-tp__badge--d1 {
    background-color: {{ section.settings.desconto1_bg_color }};
    color: {{ section.settings.desconto1_text_color }};
  }

  #res-tp-{{ section.id }} .res-tp__badge--d2 {
    background-color: {{ section.settings.desconto2_bg_color }};
    color: {{ section.settings.desconto2_text_color }};
  }

  #res-tp-{{ section.id }} .res-tp__tag--1 {
    {% if section.settings.tag1_estilo == 'solid' %}
      background-color: {{ section.settings.tag1_color }};
      color: {{ section.settings.tag1_text_color }};
    {% else %}
      background-color: transparent;
      color: {{ section.settings.tag1_color }};
      border: 2px solid {{ section.settings.tag1_color }};
    {% endif %}
  }

  #res-tp-{{ section.id }} .res-tp__tag--2 {
    {% if section.settings.tag2_estilo == 'solid' %}
      background-color: {{ section.settings.tag2_color }};
      color: {{ section.settings.tag2_text_color }};
    {% else %}
      background-color: transparent;
      color: {{ section.settings.tag2_color }};
      border: 2px solid {{ section.settings.tag2_color }};
    {% endif %}
  }

  #res-tp-{{ section.id }} .res-tp__frete-tag {
    {% if section.settings.frete_estilo == 'solid' %}
      background-color: {{ section.settings.frete_color }};
      color: {{ section.settings.frete_text_color }};
    {% else %}
      background-color: transparent;
      color: {{ section.settings.frete_color }};
      border: 2px solid {{ section.settings.frete_color }};
    {% endif %}
  }

  #res-tp-{{ section.id }} .res-tp__timer-label {
    color: {{ section.settings.timer_label_color }};
    font-size: {{ section.settings.timer_label_size }}px;
  }

  #res-tp-{{ section.id }} .res-tp__timer-display {
    background-color: {{ section.settings.timer_bg_color }};
    color: {{ section.settings.timer_text_color }};
    font-size: {{ section.settings.timer_font_size }}px;
  }

  #res-tp-{{ section.id }} .res-tp__comprar {
    background-color: {{ section.settings.buy_bg_color }};
    color: {{ section.settings.buy_text_color }};
    font-size: {{ section.settings.buy_font_size }}px;
  }

  @media screen and (max-width: 749px) {
    #res-tp-{{ section.id }} .res-tp__titulo {
      font-size: {{ section.settings.title_size_mobile }}px;
    }
    #res-tp-{{ section.id }} .res-tp__preco-atual-valor {
      font-size: {{ section.settings.price_size_mobile }}px;
    }
  }
{% endstyle %}

<div id="res-tp-{{ section.id }}" class="res-tp page-width">
  <div class="res-tp__grid">
    {%- comment -%} ══ ESQUERDA ══ {%- endcomment -%}
    <div class="res-tp__esquerda">
      {%- comment -%} Tags do topo {%- endcomment -%}
      {%- if section.settings.tag1_texto != blank or section.settings.tag2_texto != blank -%}
        <div class="res-tp__tags small-hide">
          {%- if section.settings.tag1_texto != blank -%}
            <span class="res-tp__tag res-tp__tag--1">{{ section.settings.tag1_texto }}</span>
          {%- endif -%}
          {%- if section.settings.tag2_texto != blank -%}
            <span class="res-tp__tag res-tp__tag--2">{{ section.settings.tag2_texto }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Título {%- endcomment -%}
      {%- assign titulo_final = section.settings.titulo -%}
      {%- if titulo_final == blank and prod != blank -%}
        {%- assign titulo_final = prod.title -%}
      {%- endif -%}
      {%- if titulo_final != blank -%}
        <h2 class="res-tp__titulo small-hide">{{ titulo_final }}</h2>
      {%- endif -%}

      {%- comment -%} Preço original + desconto 1 {%- endcomment -%}
      {%- if section.settings.preco_original != blank or section.settings.desconto1_texto != blank -%}
        <div class="res-tp__row res-tp__row--original">
          {%- if section.settings.preco_original != blank -%}
            <span class="res-tp__preco-original">{{ section.settings.preco_original }}</span>
          {%- endif -%}
          {%- if section.settings.desconto1_texto != blank -%}
            <span class="res-tp__badge res-tp__badge--d1">{{ section.settings.desconto1_texto }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Preço atual + desconto 2 {%- endcomment -%}
      {%- if section.settings.preco_atual != blank or section.settings.desconto2_texto != blank -%}
        <div class="res-tp__row res-tp__row--atual">
          {%- if section.settings.preco_atual != blank -%}
            <span class="res-tp__preco-atual-valor">{{ section.settings.preco_atual }}</span>
          {%- endif -%}
          {%- if section.settings.desconto2_texto != blank -%}
            <span class="res-tp__badge res-tp__badge--d2">{{ section.settings.desconto2_texto }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Parcelamento {%- endcomment -%}
      {%- if section.settings.parcelamento != blank -%}
        <p class="res-tp__parcelamento">{{ section.settings.parcelamento }}</p>
      {%- endif -%}

      {%- comment -%} Tag frete {%- endcomment -%}
      {%- if section.settings.frete_texto != blank -%}
        <div style="margin-bottom: 16px;" class="small-hide">
          <span class="res-tp__frete-tag">{{ section.settings.frete_texto }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} Cupom {%- endcomment -%}
      {%- if section.settings.cupom_codigo != blank -%}
        <div class="res-tp__cupom">
          {%- if section.settings.cupom_label != blank -%}
            <span class="res-tp__cupom-label small-hide">{{ section.settings.cupom_label }}</span>
          {%- endif -%}
          <button
            class="res-tp__cupom-codigo"
            data-codigo="{{ section.settings.cupom_codigo }}"
            aria-label="Copiar cupom {{ section.settings.cupom_codigo }}"
            type="button"
          >
            {{ section.settings.cupom_codigo }}
          </button>
          <button class="res-tp__cupom-copiar" data-codigo="{{ section.settings.cupom_codigo }}" type="button">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <span class="res-tp__cupom-copiar-texto">{{ section.settings.cupom_copy_label | default: 'Copiar' }}</span>
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ══ CENTRO (imagem) ══ {%- endcomment -%}
    <div class="res-tp__centro">
      {%- if section.settings.tag1_texto != blank or section.settings.tag2_texto != blank -%}
        <div class="res-tp__tags large-up-hide medium-hide">
          {%- if section.settings.tag1_texto != blank -%}
            <span class="res-tp__tag res-tp__tag--1">{{ section.settings.tag1_texto }}</span>
          {%- endif -%}
          {%- if section.settings.tag2_texto != blank -%}
            <span class="res-tp__tag res-tp__tag--2">{{ section.settings.tag2_texto }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- comment -%} Título {%- endcomment -%}
      {%- assign titulo_final = section.settings.titulo -%}
      {%- if titulo_final == blank and prod != blank -%}
        {%- assign titulo_final = prod.title -%}
      {%- endif -%}
      {%- if titulo_final != blank -%}
        <h2 class="res-tp__titulo large-up-hide medium-hide">{{ titulo_final }}</h2>
      {%- endif -%}
      {%- if img != blank -%}
        <div class="res-tp__imagem">
          {{
            img
            | image_url: width: 800
            | image_tag: loading: 'lazy', alt: img.alt
            | default: titulo_final
            | default: '', widths: '280, 400, 600, 800'
          }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ══ DIREITA (timer + comprar) ══ {%- endcomment -%}
    <div class="res-tp__direita">
      {%- if section.settings.timer_label != blank -%}
        <p class="res-tp__timer-label">{{ section.settings.timer_label }}</p>
      {%- endif -%}

      {%- comment -%} Product form / botão comprar {%- endcomment -%}
      {%- if prod != blank and variant != blank -%}
        <product-form class="res-tp__form" data-section-id="{{ section.id }}">
          {% assign product_form_id = 'quick-add-' | append: section.id | append: prod.id %}
          {%- form 'product',
            prod,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ prod.selected_or_first_available_variant.id }}"
              class="product-variant-id"
              {% if prod.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >
            <button
              id="{{ product_form_id }}-submit"
              type="submit"
              name="add"
              class="res-tp__comprar quick-add__submit button button--full-width button--primary"
              aria-haspopup="dialog"
              aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ prod.id }}"
              aria-live="polite"
              data-sold-out-message="true"
              {% if prod.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >
              <div class="wrapper-timmer">
                <div
                  class="res-tp__timer-display"
                  id="res-tp-timer-{{ section.id }}"
                  data-horas="{{ section.settings.timer_horas | default: 24 }}"
                  data-minutos="{{ section.settings.timer_minutos | default: 0 }}"
                  data-segundos="{{ section.settings.timer_segundos | default: 0 }}"
                  aria-live="polite"
                >
                  <div class="res-tp__timer-part">
                    <span class="res-tp__timer-num" id="res-tp-hh-{{ section.id }}">00</span>
                    <span class="res-tp__timer-unit">{{ section.settings.timer_label_h | default: 'HORAS' }}</span>
                  </div>
                  <span class="res-tp__timer-colon">:</span>
                  <div class="res-tp__timer-part">
                    <span class="res-tp__timer-num" id="res-tp-mm-{{ section.id }}">00</span>
                    <span class="res-tp__timer-unit">{{ section.settings.timer_label_m | default: 'MIN' }}</span>
                  </div>
                  <span class="res-tp__timer-colon">:</span>
                  <div class="res-tp__timer-part">
                    <span class="res-tp__timer-num" id="res-tp-ss-{{ section.id }}">00</span>
                    <span class="res-tp__timer-unit">{{ section.settings.timer_label_s | default: 'SEG' }}</span>
                  </div>
                </div>
              </div>
              <div class="wrapper-btn-content">
                <span class="svg-wrapper">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                  </svg>
                </span>

                {%- if prod.available -%}
                  {{ section.settings.buy_btn_texto | default: 'Comprar Agora' }}
                {%- else -%}
                  Esgotado
                {%- endif -%}
                <span class="svg-wrapper res-tp__comprar-arrow">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6"></path>
                  </svg>
                </span>
                {%- render 'loading-spinner' -%}
              </div>
            </button>
          {%- endform -%}
        </product-form>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var sid     = {{ section.id | json }};
    var timerEl = document.getElementById('res-tp-timer-' + sid);

    var elHH = document.getElementById('res-tp-hh-' + sid);
    var elMM = document.getElementById('res-tp-mm-' + sid);
    var elSS = document.getElementById('res-tp-ss-' + sid);

    function pad(n) { return n < 10 ? '0' + n : String(n); }

    if (timerEl) {
      var durSeg =
        parseInt(timerEl.dataset.horas,   10) * 3600 +
        parseInt(timerEl.dataset.minutos, 10) * 60   +
        parseInt(timerEl.dataset.segundos,10);

      var lsKey  = 'res-tp-end-' + sid;
      var stored = localStorage.getItem(lsKey);
      var endTs;

      if (stored && parseInt(stored, 10) > Date.now()) {
        endTs = parseInt(stored, 10);
      } else {
        endTs = Date.now() + durSeg * 1000;
        localStorage.setItem(lsKey, endTs);
      }

      function tick() {
        var diff = Math.max(0, Math.floor((endTs - Date.now()) / 1000));
        if (elHH) elHH.textContent = pad(Math.floor(diff / 3600));
        if (elMM) elMM.textContent = pad(Math.floor((diff % 3600) / 60));
        if (elSS) elSS.textContent = pad(diff % 60);
        if (diff > 0) setTimeout(tick, 1000);
      }

      tick();
    }

    // ── Coupon copy ──
    document.querySelectorAll('#res-tp-' + sid + ' [data-codigo]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var code = this.dataset.codigo;
        var textoEl = this.querySelector('.res-tp__cupom-copiar-texto');
        navigator.clipboard.writeText(code).then(function () {
          if (textoEl) {
            var orig = textoEl.textContent;
            textoEl.textContent = 'Copiado!';
            setTimeout(function () { textoEl.textContent = orig; }, 2000);
          }
        }).catch(function () {
          // fallback para navegadores sem clipboard API
          var ta = document.createElement('textarea');
          ta.value = code;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "RES - Timer Produto",
  "class": "res-timer-produto-section",
  "settings": [
    {
      "type": "header",
      "content": "Produto"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produto"
    },
    {
      "type": "image_picker",
      "id": "imagem",
      "label": "Imagem (substitui a do produto)"
    },
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "titulo",
      "label": "Título",
      "info": "Se vazio, usa o nome do produto."
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Tamanho (desktop)",
      "default": 38
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 18,
      "max": 52,
      "step": 2,
      "unit": "px",
      "label": "Tamanho (mobile)",
      "default": 28
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Peso da fonte",
      "default": "800",
      "options": [
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — Semi-bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra-bold" }
      ]
    },
    {
      "type": "header",
      "content": "Tags do Topo"
    },
    {
      "type": "text",
      "id": "tag1_texto",
      "label": "Tag 1 — Texto",
      "default": "OFERTA 24H"
    },
    {
      "type": "select",
      "id": "tag1_estilo",
      "label": "Tag 1 — Estilo",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Preenchida" },
        { "value": "outline", "label": "Contorno" }
      ]
    },
    {
      "type": "color",
      "id": "tag1_color",
      "label": "Tag 1 — Cor (fundo ou borda)",
      "default": "#f97316"
    },
    {
      "type": "color",
      "id": "tag1_text_color",
      "label": "Tag 1 — Cor do texto",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "tag2_texto",
      "label": "Tag 2 — Texto",
      "default": "COMPRE 3 LEVE 5"
    },
    {
      "type": "select",
      "id": "tag2_estilo",
      "label": "Tag 2 — Estilo",
      "default": "outline",
      "options": [
        { "value": "solid", "label": "Preenchida" },
        { "value": "outline", "label": "Contorno" }
      ]
    },
    {
      "type": "color",
      "id": "tag2_color",
      "label": "Tag 2 — Cor (fundo ou borda)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tag2_text_color",
      "label": "Tag 2 — Cor do texto (apenas preenchida)",
      "default": "#1a5c2a"
    },
    {
      "type": "header",
      "content": "Preços"
    },
    {
      "type": "text",
      "id": "preco_original",
      "label": "Preço original (riscado)",
      "default": "de R$ 499,50"
    },
    {
      "type": "text",
      "id": "desconto1_texto",
      "label": "Badge desconto 1",
      "default": "40% OFF"
    },
    {
      "type": "color",
      "id": "desconto1_bg_color",
      "label": "Badge desconto 1 — Fundo",
      "default": "#dc2626"
    },
    {
      "type": "color",
      "id": "desconto1_text_color",
      "label": "Badge desconto 1 — Texto",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "preco_atual",
      "label": "Preço atual",
      "default": "por R$ 297,90"
    },
    {
      "type": "color",
      "id": "price_atual_color",
      "label": "Cor do preço atual",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "price_size_desktop",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do preço (desktop)",
      "default": 34
    },
    {
      "type": "range",
      "id": "price_size_mobile",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do preço (mobile)",
      "default": 26
    },
    {
      "type": "select",
      "id": "price_weight",
      "label": "Peso do preço",
      "default": "800",
      "options": [
        { "value": "600", "label": "600 — Semi-bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra-bold" }
      ]
    },
    {
      "type": "text",
      "id": "desconto2_texto",
      "label": "Badge desconto 2",
      "default": "+20%OFF COM CUPOM"
    },
    {
      "type": "color",
      "id": "desconto2_bg_color",
      "label": "Badge desconto 2 — Fundo",
      "default": "#f97316"
    },
    {
      "type": "color",
      "id": "desconto2_text_color",
      "label": "Badge desconto 2 — Texto",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Parcelamento e Frete"
    },
    {
      "type": "text",
      "id": "parcelamento",
      "label": "Texto de parcelamento",
      "default": "ou até 10x de R$ 34,92"
    },
    {
      "type": "text",
      "id": "frete_texto",
      "label": "Tag de frete",
      "default": "FRETE GRÁTIS"
    },
    {
      "type": "select",
      "id": "frete_estilo",
      "label": "Tag frete — Estilo",
      "default": "outline",
      "options": [
        { "value": "solid", "label": "Preenchida" },
        { "value": "outline", "label": "Contorno" }
      ]
    },
    {
      "type": "color",
      "id": "frete_color",
      "label": "Tag frete — Cor (fundo ou borda)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "frete_text_color",
      "label": "Tag frete — Cor do texto (apenas preenchida)",
      "default": "#1a5c2a"
    },
    {
      "type": "header",
      "content": "Cupom"
    },
    {
      "type": "text",
      "id": "cupom_label",
      "label": "Rótulo",
      "default": "USE O CUPOM:"
    },
