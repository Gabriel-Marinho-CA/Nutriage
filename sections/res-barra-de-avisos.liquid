{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

<style>
  .marquee-wrapper {
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .marquee-content {
    display: flex;
    width: max-content;
    animation: marquee {{ section.settings.marquee_speed }}s linear infinite;
  }

  .marquee-content:hover {
    animation-play-state: paused;
  }

  .marquee-item {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding: 0 {{ section.settings.gap_between_items | default: 32 }}px;
  }

  .marquee-item .announcement-bar__message {
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .marquee-item .announcement-bar__image {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .marquee-item .announcement-bar__image img {
    display: block;
    height: auto;
    object-fit: contain;
  }

  .utility-bar {
    color: inherit;
    font-family: var(--font-body-family);
    font-weight: 600;
  }

  .utility-bar .announcement-bar__message,
  .utility-bar .announcement-bar__link {
    font-family: var(--font-body-family);
    font-weight: 400;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
  if section.settings.enable_country_selector or section.settings.enable_language_selector
    assign language_country_selector = true
  endif
-%}

{% if social_icons %}
  {{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{% endif %}

<div
  class="utility-bar{% if section.settings.show_line_separator and section.blocks.size > 0 %} utility-bar--bottom-border{% elsif section.settings.show_line_separator and section.settings.show_social and social_icons%} utility-bar--bottom-border-social-only{% endif %}{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header-localization{% endif %}"
  style="{% if section.settings.background_color %}background-color: {{ section.settings.background_color }};{% endif %}{% if section.settings.text_color %}color: {{ section.settings.text_color }};{% endif %}{% if section.settings.padding_top %}padding-top: {{ section.settings.padding_top }}px;{% endif %}{% if section.settings.padding_bottom %}padding-bottom: {{ section.settings.padding_bottom }}px;{% endif %}{% if section.settings.enable_borders %}border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};{% endif %}"
>
  {%- if section.blocks.size >= 1 -%}
    <div
      class="announcement-bar marquee-wrapper"
      role="region"
      aria-label="Comunicados"
    >
      <div class="marquee-content">
        {%- for i in (1..10) -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.text != blank or block.settings.image != blank -%}
              <div class="marquee-item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    class="announcement-bar__link link link--text focus-inset"
                    style="{% if section.settings.text_color %}color: {{ section.settings.text_color }};{% endif %}display: flex; align-items: center; gap: 0.5rem; text-decoration: none;{% if block.settings.background_color %}background-color: {{ block.settings.background_color }};{% endif %}{% if block.settings.enable_border %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}border-radius: {{ block.settings.border_radius }}px;padding: {{ block.settings.padding }}px;{% if block.settings.width > 0 %}width: {{ block.settings.width }}px;{% endif %}{% if block.settings.height > 0 %}height: {{ block.settings.height }}px;{% endif %}"
                  >
                {%- else -%}
                  <div style="display: flex; align-items: center; gap: 0.5rem;{% if block.settings.background_color %}background-color: {{ block.settings.background_color }};{% endif %}{% if block.settings.enable_border %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}border-radius: {{ block.settings.border_radius }}px;padding: {{ block.settings.padding }}px;{% if block.settings.width > 0 %}width: {{ block.settings.width }}px;{% endif %}{% if block.settings.height > 0 %}height: {{ block.settings.height }}px;{% endif %}">
                {%- endif -%}
                {%- if block.settings.image != blank and block.settings.image_position == 'before' -%}
                  <div class="announcement-bar__image" style="width: {{ block.settings.image_width }}px;">
                    {{
                      block.settings.image
                      | image_url: width: block.settings.image_width
                      | image_tag: loading: 'lazy', alt: block.settings.image.alt
                      | default: block.settings.text
                    }}
                  </div>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div
                    class="announcement-bar__message h5"
                    style="{% if section.settings.text_color %}color: {{ section.settings.text_color }};{% endif %}{% if block.settings.text_size_px %}font-size: {{ block.settings.text_size_px }}px;{% endif %}{% if section.settings.letter_spacing %}letter-spacing: {{ section.settings.letter_spacing }}px;{% endif %}"
                  >
                    {{ block.settings.text }}
                  </div>
                {%- endif -%}
                {%- if block.settings.image != blank and block.settings.image_position == 'after' -%}
                  <div class="announcement-bar__image" style="width: {{ block.settings.image_width }}px;">
                    {{
                      block.settings.image
                      | image_url: width: block.settings.image_width
                      | image_tag: loading: 'lazy', alt: block.settings.image.alt
                      | default: block.settings.text
                    }}
                  </div>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- else -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
  {%- if section.settings.show_social and social_icons or language_country_selector -%}
    <div class="page-width utility-bar__grid{% if language_country_selector or section.settings.show_social and social_icons %} utility-bar__grid--2-col{% endif %}">
      {%- if section.settings.show_social and social_icons -%}
        {%- render 'social-icons' -%}
      {%- endif -%}
      <div class="localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'AnnouncementCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="AnnouncementCountryLabel">País/Região</h2>
                {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'AnnouncementLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="AnnouncementLanguageLabel">Idioma</h2>
                {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "RES - Barra de Avisos",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Velocidade do deslizamento",
      "default": 20,
      "info": "Valores menores = mais rápido"
    },
    {
      "type": "range",
      "id": "gap_between_items",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento entre comunicados",
      "default": 32,
      "info": "Gap entre cada comunicado"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#1f2021"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "Mostrar separador de linha"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 0
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": -2,
      "max": 5,
      "step": 0.1,
      "unit": "px",
      "label": "Espaçamento entre letras",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_borders",
      "default": false,
      "label": "Ativar bordas",
      "info": "Para ativar as bordas superiores e inferiores, ative o campo acima"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Largura da borda",
      "default": 1,
      "visible_if": "{{ section.settings.enable_borders == true }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Cor da borda",
      "default": "#e0e0e0",
      "visible_if": "{{ section.settings.enable_borders == true }}"
    },
    {
      "type": "header",
      "content": "Utilidades"
    },
    {
      "type": "paragraph",
      "content": "Configure opções adicionais como redes sociais e seletores de país/idioma"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "Mostrar redes sociais",
      "info": "Para editar as contas das redes sociais, vá para Configurações do tema"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "Habilitar seletor de país",
      "info": "Para adicionar um país, vá para suas configurações de mercado"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "Habilitar seletor de idioma",
      "info": "Para adicionar um idioma, vá para suas configurações de idioma"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Comunicado",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Bem-vindo à nossa loja</p>",
          "label": "Texto"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "text_size_px",
          "min": 10,
          "max": 48,
          "step": 1,
          "unit": "px",
          "label": "Tamanho do texto",
          "default": 14
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ícone/Imagem"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 12,
          "max": 80,
          "step": 2,
          "unit": "px",
          "label": "Largura da imagem",
          "default": 24
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Posição da imagem",
          "default": "before",
          "options": [
            {
              "value": "before",
              "label": "Antes do texto"
            },
            {
              "value": "after",
              "label": "Depois do texto"
            }
          ]
        },
        {
          "type": "header",
          "content": "Estilo do comunicado"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Cor de fundo",
          "info": "Deixe em branco para usar transparente"
        },
        {
          "type": "checkbox",
          "id": "enable_border",
          "default": false,
          "label": "Ativar borda"
        },
        {
          "type": "range",
          "id": "border_width",
          "min": 1,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Largura da borda",
          "default": 1
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Cor da borda",
          "default": "#e0e0e0"
        },
        {
          "type": "range",
          "id": "border_radius",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "Border radius",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding",
          "min": 0,
          "max": 40,
          "step": 2,
          "unit": "px",
          "label": "Padding interno",
          "default": 12,
          "info": "Espaçamento interno do comunicado"
        },
        {
          "type": "header",
          "content": "Dimensões"
        },
        {
          "type": "range",
          "id": "width",
          "min": 0,
          "max": 800,
          "step": 10,
          "unit": "px",
          "label": "Largura (width)",
          "default": 0,
          "info": "Deixe em 0 para largura automática"
        },
        {
          "type": "range",
          "id": "height",
          "min": 0,
          "max": 200,
          "step": 5,
          "unit": "px",
          "label": "Altura (height)",
          "default": 0,
          "info": "Deixe em 0 para altura automática"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "res - Barra de Avisos",
      "category": "Res- Seções",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
