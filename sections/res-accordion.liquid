{% comment %}
  RES Accordion — Imagem + Blocos Acordeão
  CSS: assets/res-accordion.css
  Left: title + image
  Right: description + accordion blocks (title, description, tags 1–5, button)
{% endcomment %}

{{ 'res-accordion.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #res-acc-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    --res-acc-title-color:   {{ section.settings.title_color }};
    --res-acc-closed-bg:     {{ section.settings.item_closed_bg }};
    --res-acc-closed-color:  {{ section.settings.item_closed_color }};
    --res-acc-open-bg:       {{ section.settings.item_open_bg }};
    --res-acc-open-color:    {{ section.settings.item_open_color }};
    --res-acc-btn-bg:        {{ section.settings.btn_bg }};
    --res-acc-btn-color:     {{ section.settings.btn_color }};
    --res-acc-bg-color:      {{ section.settings.bg_color }};
    --res-acc-description-color:      {{ section.settings.description_color }};
    --res-acc-button-color:      {{ section.settings.button_color }};

  }
  @media screen and (min-width: 750px) {
    #res-acc-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="res-acc-{{ section.id }}"
  class="res-acc color-{{ section.settings.color_scheme }} gradient"
>
  <div class="res-acc__inner page-width scroll-trigger animate--slide-in">
    {%- comment -%} ── Lado esquerdo: título + imagem ── {%- endcomment -%}
    <div class="res-acc__left">
      {%- if section.settings.title != blank -%}
        <h2 class="res-acc__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.image != blank -%}
        <div class="res-acc__img-wrap">
          <img
            src="{{ section.settings.image | image_url: width: 700 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="700"
            height="{{ 700 | divided_by: section.settings.image.aspect_ratio | round }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Lado direito: descrição + acordeão ── {%- endcomment -%}
    <div class="res-acc__right">
      {%- if section.settings.description != blank -%}
        <div class="res-acc__desc">{{ section.settings.description }}</div>
      {%- endif -%}

      <div class="res-acc__list">
        {%- for block in section.blocks -%}
          <div class="res-acc__item" {{ block.shopify_attributes }}>
            <details
              class="res-acc__details"
            {% comment %}  {% if forloop.first %}
                open
              {% endif %}
               {% endcomment %}
            >
              <summary class="res-acc__summary">
                <span class="res-acc__summary-label">{{ block.settings.title | escape }}</span>
                {% comment %} <span class="res-acc__chevron" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </span> {% endcomment %}
              </summary>

              <div class="res-acc__body">
                {%- if block.settings.description != blank -%}
                  <p class="res-acc__body-desc">{{ block.settings.description }}</p>
                {%- endif -%}

                <div class="res-acc__tags">
                  {%- for i in (1..5) -%}
                    {%- assign tag_key = 'tag_' | append: i -%}
                    {%- assign tag_val = block.settings[tag_key] -%}
                    {%- if tag_val != blank -%}
                      <span class="res-acc__tag">{{ tag_val | escape }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_url | default: '#' }}"
                    class="res-acc__btn"
                  >
                    {{- block.settings.button_label | escape -}}
                  </a>
                {%- endif -%}
              </div>
            </details>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
  {% if section.settings.label_btn != blank %}
    <div class="res-fc__view-all page-width">
      <a class="res-fc__view-all-btn-accordion button button--secondary" href="{{  section.settings.link_btn }}" title="{{  section.settings.label_btn  }}">
        {{ section.settings.label_btn }}
      </a>
    </div>
  {% endif %}
</section>

<script>
  (function () {
    var section = document.getElementById('res-acc-{{ section.id }}');
    if (!section) return;

    var allDetails = Array.prototype.slice.call(section.querySelectorAll('.res-acc__details'));

    allDetails.forEach(function (det) {
      det.querySelector('summary').addEventListener('click', function (e) {
        e.preventDefault();

        if (det.open) {
          animateClose(det);
        } else {
          // Close any open sibling first
          allDetails.forEach(function (other) {
            if (other !== det && other.open) animateClose(other);
          });
          det.setAttribute('open', '');
        }
      });
    });

    function animateClose(det) {
      var body = det.querySelector('.res-acc__body');
      if (!body) {
        det.removeAttribute('open');
        return;
      }

      body.classList.add('res-acc__body--closing');
      body.addEventListener(
        'animationend',
        function handler() {
          body.removeEventListener('animationend', handler);
          body.classList.remove('res-acc__body--closing');
          det.removeAttribute('open');
        },
        { once: true }
      );
    }
  })();
</script>

