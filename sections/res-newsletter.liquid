{% comment %}
  RES Newsletter Bar — Texto + Formulário + Ícones Sociais
  CSS: assets/res-newsletter.css
{% endcomment %}

{{ 'res-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #res-nl-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    --res-nl-bg:           {{ section.settings.bg_color }};
    --res-nl-text-color:   {{ section.settings.text_color }};
    --res-nl-btn-bg:       {{ section.settings.btn_bg }};
    --res-nl-btn-color:    {{ section.settings.btn_color }};
    --res-nl-social-color: {{ section.settings.social_color }};
  }
  @media screen and (min-width: 750px) {
    #res-nl-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="res-nl-{{ section.id }}" class="res-nl">
  <div class="res-nl__inner page-width scroll-trigger animate--slide-in">

    {%- if section.settings.label != blank -%}
      <p class="res-nl__label">{{ section.settings.label | escape }}</p>
    {%- endif -%}

    {% form 'customer', class: 'res-nl__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="res-nl__success">
          {{ 'newsletter.success' | t }}
        </p>
      {%- else -%}

        {%- if section.settings.show_name -%}
          <input
            type="text"
            name="contact[first_name]"
            class="res-nl__input"
            placeholder="{{ section.settings.placeholder_name | default: 'Seu nome' | escape }}"
            autocomplete="given-name"
          >
        {%- endif -%}

        <input
          id="ResNewsletterEmail--{{ section.id }}"
          type="email"
          name="contact[email]"
          class="res-nl__input"
          placeholder="{{ section.settings.placeholder_email | default: 'Seu e-mail' | escape }}"
          value="{{ form.email }}"
          aria-required="true"
          autocomplete="email"
          required
          {% if form.errors %}aria-invalid="true"{% endif %}
        >

        <button type="submit" class="res-nl__btn">
          {{ section.settings.btn_label | default: 'Assinar' | escape }}
        </button>

        {%- if form.errors -%}
          <p class="res-nl__error">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}

      {%- endif -%}
    {% endform %}

    {%- liquid
      assign has_social = false
      if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_whatsapp_link != blank
        assign has_social = true
      endif
    -%}
    {%- if has_social -%}
      <div class="res-nl__social">

        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.instagram' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.facebook' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.twitter' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.youtube' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zm-12.54 9V8.6l5.73 3.4-5.73 3.42z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_whatsapp_link != blank -%}
          <a href="{{ settings.social_whatsapp_link }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.505 5.829L.057 23.982l6.305-1.654A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.663-.523-5.18-1.434l-.371-.22-3.844 1.007 1.027-3.748-.242-.386A9.935 9.935 0 012 12c0-5.523 4.478-10 10-10s10 4.477 10 10-4.478 10-10 10z"/>
            </svg>
          </a>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Newsletter Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Texto do label",
      "default": "Receba as nossas últimas novidades"
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "label": "Exibir campo Nome",
      "default": true
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Placeholder — Nome",
      "default": "Seu nome"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Placeholder — E-mail",
      "default": "Seu e-mail"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto do botão",
      "default": "Assinar"
    },
    {
      "type": "header",
      "content": "Redes Sociais"
    },
    {
      "type": "paragraph",
      "content": "Os links são gerenciados em Configurações do tema → Redes sociais."
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#C9A870"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#1A4789"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fundo do botão",
      "default": "#1A4789"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Texto do botão",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "social_color",
      "label": "Cor dos ícones sociais",
      "default": "#1A4789"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Newsletter Bar",
      "category": "Res - Seções"
    }
  ]
}
{% endschema %}
