{% comment %}
  RES Newsletter Bar — Texto + Formulário + Ícones Sociais
  CSS: assets/res-newsletter.css
{% endcomment %}

{{ 'res-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #res-nl-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    --res-nl-bg:           {{ section.settings.bg_color }};
    --res-nl-text-color:   {{ section.settings.text_color }};
    --res-nl-btn-bg:       {{ section.settings.btn_bg }};
    --res-nl-btn-color:    {{ section.settings.btn_color }};
    --res-nl-social-color: {{ section.settings.social_color }};
  }
  @media screen and (min-width: 750px) {
    #res-nl-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="res-nl-{{ section.id }}" class="res-nl">
  <div class="res-nl__inner page-width">

    {%- if section.settings.label != blank -%}
      <p class="res-nl__label">{{ section.settings.label | escape }}</p>
    {%- endif -%}

    {% form 'customer', class: 'res-nl__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="res-nl__success">
          {{ 'newsletter.success' | t }}
        </p>
      {%- else -%}

        {%- if section.settings.show_name -%}
          <input
            type="text"
            name="contact[first_name]"
            class="res-nl__input"
            placeholder="{{ section.settings.placeholder_name | default: 'Seu nome' | escape }}"
            autocomplete="given-name"
          >
        {%- endif -%}

        <input
          id="ResNewsletterEmail--{{ section.id }}"
          type="email"
          name="contact[email]"
          class="res-nl__input"
          placeholder="{{ section.settings.placeholder_email | default: 'Seu e-mail' | escape }}"
          value="{{ form.email }}"
          aria-required="true"
          autocomplete="email"
          required
          {% if form.errors %}aria-invalid="true"{% endif %}
        >

        <button type="submit" class="res-nl__btn">
          {{ section.settings.btn_label | default: 'Assinar' | escape }}
        </button>

        {%- if form.errors -%}
          <p class="res-nl__error">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}

      {%- endif -%}
    {% endform %}

    {%- if section.settings.instagram_url != blank or section.settings.facebook_url != blank or section.settings.whatsapp_url != blank -%}
      <div class="res-nl__social">

        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="17" height="17">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.whatsapp_url != blank -%}
          <a href="{{ section.settings.whatsapp_url }}" class="res-nl__social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.345.223-.643.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.172.198-.296.298-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
            </svg>
          </a>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Newsletter Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Texto do label",
      "default": "Receba as nossas últimas novidades"
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "label": "Exibir campo Nome",
      "default": true
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Placeholder — Nome",
      "default": "Seu nome"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Placeholder — E-mail",
      "default": "Seu e-mail"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto do botão",
      "default": "Assinar"
    },
    {
      "type": "header",
      "content": "Redes Sociais"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "text",
      "id": "whatsapp_url",
      "label": "WhatsApp URL (ex: https://wa.me/55...)"
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#C9A870"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#1A4789"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fundo do botão",
      "default": "#1A4789"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Texto do botão",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "social_color",
      "label": "Cor dos ícones sociais",
      "default": "#1A4789"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Newsletter Bar",
      "category": "Res - Seções"
    }
  ]
}
{% endschema %}
