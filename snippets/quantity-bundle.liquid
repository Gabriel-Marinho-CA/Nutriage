{%- comment -%}
  Snippet: quantity-bundle
  Suporta metafield custom.kits como list.product_reference
{%- endcomment -%}

{{ 'quantity-bundle.css' | asset_url | stylesheet_tag }}
<script src="{{ 'quantity-bundle.js' | asset_url }}" defer="defer"></script>

{%- assign qb_kits = product.metafields.custom.kits.value -%}

<quantity-bundle
  class="quantity-bundle"
  data-section-id="{{ section.id }}"
  data-form-id="{{ product_form_id }}"
  {{ block.shopify_attributes }}
>

<p class="qb-heading">
  {{ block.settings.heading | default: 'Escolha sua opção:' }}
  <strong class="qb-heading-qty"></strong>
</p>

<div class="qb-cards">


  {%- comment -%}
  ---- KITS (metafield)
  {%- endcomment -%}

  {%- if qb_kits != blank -%}

    {%- for kit in qb_kits -%}

      {%- assign qb_v = kit.selected_or_first_available_variant -%}
      {%- assign qb_compare = qb_v.compare_at_price | default: qb_v.price -%}

      <div class="qb-card"
        data-variant-id="{{ qb_v.id }}"
        data-price="{{ qb_v.price }}"
        data-compare="{{ qb_compare }}"
        data-installment-count="{{  }}"
        data-installment-label="3x sem juros de"
        data-qty-label="{{ kit.title | escape }}"
      >

        {%- if forloop.index == 1 and block.settings.kit1_show_badge -%}
          <span class="qb-badge">
            {{ block.settings.kit1_badge | default: 'Mais vendido' }}
          </span>
        {%- endif -%}

        {%- if forloop.index == 2 and block.settings.kit2_show_badge -%}
          <span class="qb-badge">
            {{ block.settings.kit2_badge }}
          </span>
        {%- endif -%}

        <div class="qb-card-img">

          {%- if kit.featured_image -%}

            <img
              src="{{ kit.featured_image | image_url: width: 300 }}"
              alt="{{ kit.title | escape }}"
              width="150"
              height="150"
              loading="lazy"
            >

          {%- endif -%}

        </div>

        <div class="qb-radio">
          <span class="qb-radio-dot"></span>
        </div>

        <strong class="qb-card-title">
          {{ kit.title }}
        </strong>

        <span class="qb-installment-label">
          3x sem juros de
        </span>

        <span class="qb-price-big">
          {{ qb_v.price | divided_by: block.settings.main_installment_count  | money }}
        </span>

        <span class="qb-price-cash">
          ou {{ qb_compare | money }} à vista
        </span>

      </div>

    {%- endfor -%}

  {%- endif -%}

  {%- comment -%}
  ---- PRODUTO PRINCIPAL (1 unidade)
  {%- endcomment -%}

  {%- assign qb_v = product.selected_or_first_available_variant -%}
  {%- assign qb_compare = qb_v.compare_at_price | default: qb_v.price -%}

  <div class="qb-card"
    data-variant-id="{{ qb_v.id }}"
    data-price="{{ qb_v.price }}"
    data-compare="{{ qb_compare }}"
    data-installment-count="{{ block.settings.main_installment_count | default: 3 }}"
    data-installment-label="{{ block.settings.main_installment_label | default: '3x sem juros de' | escape }}"
    data-qty-label="{{ block.settings.main_qty_label | default: '1 unidade' | escape }}"
  >

    {%- if block.settings.main_show_badge -%}
      <span class="qb-badge">{{ block.settings.main_badge }}</span>
    {%- endif -%}

    <div class="qb-card-img">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 300 }}"
          alt="{{ product.title | escape }}"
          width="150"
          height="150"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="qb-radio">
      <span class="qb-radio-dot"></span>
    </div>

    <strong class="qb-card-title">
      {{ block.settings.main_title | default: '1 unidade' }}
    </strong>

    <span class="qb-installment-label">
      {{ block.settings.main_installment_label | default: '3x sem juros de' }}
    </span>

    <span class="qb-price-big">
      
      {{ qb_v.price | divided_by: block.settings.main_installment_count | money }}
    </span>

    <span class="qb-price-cash">
      ou {{ qb_compare | money }} à vista
    </span>

  </div>

</div>


<div class="qb-summary">

  <span class="qb-summary-badge" hidden></span>

  <s class="qb-summary-compare" hidden></s>

  <span class="qb-summary-price"></span>

  <span class="qb-summary-unit"></span>

</div>

</quantity-bundle>