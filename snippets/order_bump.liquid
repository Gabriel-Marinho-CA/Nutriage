{%- if settings.cart_drawer_collection != blank -%}
  {%- liquid
    assign cart_product_ids = ''
    for item in cart.items
      assign cart_product_ids = cart_product_ids | append: item.product_id | append: ','
    endfor

    assign bump_products = settings.cart_drawer_collection.products
    assign visible_count = 0
    for product in bump_products
      assign pid_check = product.id | append: ','
      unless cart_product_ids contains pid_check
        assign visible_count = visible_count | plus: 1
      endunless
    endfor
  -%}

  {%- if visible_count > 0 -%}
    {{ 'component-order-bump.css' | asset_url | stylesheet_tag }}

    <order-bump-slider class="order-bump">
      <div class="order-bump__header">
        <p class="order-bump__title">Adicione também</p>
        <div class="order-bump__nav">
          <button class="order-bump__nav-btn order-bump__prev" type="button" aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="order-bump__nav-btn order-bump__next" type="button" aria-label="Próximo">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>

      <div class="swiper order-bump__swiper">
        <div class="swiper-wrapper">
          {%- for product in bump_products -%}
            {%- assign pid_check = product.id | append: ',' -%}
            {%- unless cart_product_ids contains pid_check -%}
              {%- assign variant = product.selected_or_first_available_variant -%}
              <div class="swiper-slide">
                <div class="order-bump__card">
                  <div class="order-bump__img-wrap">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 120 }}"
                        alt="{{ product.title | escape }}"
                        width="60"
                        height="60"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </div>
                  <div class="order-bump__info">
                    <p class="order-bump__name">{{ product.title | escape }}</p>
                    <p class="order-bump__price">{{ variant.price | money }}</p>
                  </div>
                  <button
                    class="order-bump__add-btn"
                    type="button"
                    data-variant-id="{{ variant.id }}"
                  >
                    Adicionar
                  </button>
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </order-bump-slider>
  {%- endif -%}
{%- endif -%}
