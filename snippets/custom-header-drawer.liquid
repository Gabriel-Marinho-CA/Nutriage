{% comment %}
  Custom Header Drawer — Mobile/Tablet slide-in menu
  CSS: assets/custom-header-drawer.css
  JS:  assets/custom-header-drawer.js
{% endcomment %}

{{ 'custom-header-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-header-drawer.js' | asset_url }}" defer="defer"></script>

{%- comment -%} ── Hamburger trigger button ── {%- endcomment -%}
<button
  class="custom-drawer-trigger header__icon header__icon--menu"
  aria-label="{{ 'sections.header.menu' | t }}"
  aria-expanded="false"
  aria-controls="custom-drawer"
>
  <span class="svg-wrapper">
    {{- 'icon-hamburger.svg' | inline_asset_content -}}
  </span>
</button>

{%- comment -%} ── Overlay (closes drawer when clicked) ── {%- endcomment -%}
<div class="custom-drawer-overlay" aria-hidden="true"></div>

{%- comment -%} ── Drawer panel ── {%- endcomment -%}
<div
  id="custom-drawer"
  class="custom-drawer"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'sections.header.menu' | t }}"
>

  {%- comment -%} Close row {%- endcomment -%}
  <div class="custom-drawer__close-row">
    <button class="custom-drawer__close-btn" aria-label="Fechar menu">
      Fechar
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  {%- comment -%} Scrollable body {%- endcomment -%}
  <div class="custom-drawer__body">

    {%- comment -%} ── Navigation ── {%- endcomment -%}
    <nav class="custom-drawer__nav" aria-label="Menu principal">
      <ul class="custom-drawer__nav-list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="custom-drawer__nav-item">
            {%- if link.links != blank -%}
              <details id="custom-drawer-details-{{ forloop.index }}">
                <summary class="custom-drawer__nav-summary">
                  {{ link.title | escape }}
                  {%- comment -%} Caret toggles open/close {%- endcomment -%}
                  <svg class="custom-drawer__caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <ul class="custom-drawer__sub-list" role="list">
                  {%- for childlink in link.links -%}
                    <li>
                      <a
                        href="{{ childlink.url }}"
                        class="custom-drawer__sub-link{% if childlink.current %} custom-drawer__sub-link--active{% endif %}"
                        {% if childlink.current %}aria-current="page"{% endif %}
                      >
                        {{ childlink.title | escape }}
                        <svg class="custom-drawer__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="5" y1="12" x2="19" y2="12"/>
                          <polyline points="12 5 19 12 12 19"/>
                        </svg>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            {%- else -%}
              <a
                href="{{ link.url }}"
                class="custom-drawer__nav-link{% if link.current %} custom-drawer__nav-link--active{% endif %}"
                {% if link.current %}aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
                <svg class="custom-drawer__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} ── Utility links ── {%- endcomment -%}
    <div class="custom-drawer__utilities">

      {%- comment -%} Carrinho {%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="custom-drawer__utility-link">
        Seu carrinho
        <span class="custom-drawer__util-icon-wrap">
          <span class="custom-drawer__util-icon">
            {{- 'icon-cart.svg' | inline_asset_content -}}
          </span>
          {%- if cart.item_count > 0 -%}
            <span class="custom-drawer__cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </span>
      </a>

      {%- comment -%} Conta {%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="custom-drawer__utility-link"
          rel="nofollow"
        >
          Sua conta
          <span class="custom-drawer__util-icon">
            {{- 'icon-account.svg' | inline_asset_content -}}
          </span>
        </a>
      {%- endif -%}

      {%- comment -%} Ajuda e suporte {%- endcomment -%}
      <a
        href="{{ section.settings.link_help | default: '#' }}"
        class="custom-drawer__utility-link"
      >
        Ajuda e suporte
        <span class="custom-drawer__util-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="1" y="1" width="26" height="26" rx="5" stroke="#1A4789" stroke-width="1.8"/>
            <path d="M10.5 10.5C10.5 8.567 12.067 7 14 7C15.933 7 17.5 8.567 17.5 10.5C17.5 12.2 16.3 13.62 14.7 13.94V15.75H13.3V12.6L14 12.5C15.38 12.3 16.1 11.47 16.1 10.5C16.1 9.34 15.16 8.4 14 8.4C12.84 8.4 11.9 9.34 11.9 10.5H10.5Z" fill="#1A4789"/>
            <circle cx="14" cy="18.5" r="1" fill="#1A4789"/>
          </svg>
        </span>
      </a>

    </div>

    {%- comment -%} ── Social links ── {%- endcomment -%}
    {%- liquid
      assign has_social = false
      if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_pinterest_link != blank
        assign has_social = true
      endif
    -%}
    {%- if has_social -%}
      <div class="custom-drawer__social">

        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="custom-drawer__social-link" aria-label="{{ 'general.social.links.instagram' | t }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="custom-drawer__social-link" aria-label="{{ 'general.social.links.facebook' | t }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="custom-drawer__social-link" aria-label="{{ 'general.social.links.twitter' | t }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="custom-drawer__social-link" aria-label="{{ 'general.social.links.youtube' | t }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zm-12.54 9V8.6l5.73 3.4-5.73 3.42z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- comment -%} WhatsApp — uses social_pinterest_link slot or a custom setting if you prefer {%- endcomment -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" class="custom-drawer__social-link" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.099 1.505 5.829L.057 23.982l6.305-1.654A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.663-.523-5.18-1.434l-.371-.22-3.844 1.007 1.027-3.748-.242-.386A9.935 9.935 0 012 12c0-5.523 4.478-10 10-10s10 4.477 10 10-4.478 10-10 10z"/>
            </svg>
          </a>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>{%- comment -%} /.custom-drawer__body {%- endcomment -%}
</div>{%- comment -%} /.custom-drawer {%- endcomment -%}
